{
  "name": "persistent-cache-case",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build:all": "pnpm run test:persistent-cache",
    "build:rspack": "rspack build --config rspack.config.cjs",
    "build:turbopack": "TURBO_ENGINE_IGNORE_DIRTY=1 cargo run --manifest-path ../../../crates/turbopack-cli/Cargo.toml -- build --dir . --root . --target node --no-minify --no-sourcemap --persistent-caching --cache-dir .turbopack/persistent-cache src/entry.js",
    "build:webpack": "webpack --config webpack.config.cjs",
    "start:rspack": "node dist/rspack/entry.js",
    "start:turbopack": "node dist/entry.entry.js",
    "start:webpack": "node dist/webpack/entry.js",
    "test:persistent-cache": "node scripts/expect-persistent-cache.cjs"
  },
  "devDependencies": {
    "@rspack/cli": "^2.0.6",
    "@rspack/core": "^2.0.6",
    "webpack": "^5.107.2",
    "webpack-cli": "^7.0.3"
  },
  "packageManager": "pnpm@10.33.0"
}
